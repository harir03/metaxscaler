# ──────────────────────────────────────────────
# Credit Approval Environment — Environment Variables
# ──────────────────────────────────────────────
# Copy to .env:  cp .env.example .env

# ── OpenEnv Required ──
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
HF_TOKEN=<your-hf-token>
IMAGE_NAME=<your-local-docker-image>

# ── Environment Server ──
ENV_URL=http://localhost:8000

# ── Task Selection (optional) ──
# Uncomment to run specific task in inference.py
# TASK_NAME=credit-approval-easy

# ── Intelli-Credit Backend (optional — for advanced features) ──
APP_ENV=development
APP_DEBUG=true

# LLM
ANTHROPIC_API_KEY=

# Research APIs (optional)
TAVILY_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=

# PostgreSQL
POSTGRES_DB=intellicredit
POSTGRES_USER=intellicredit
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# ChromaDB
CHROMADB_HOST=localhost
CHROMADB_PORT=8100

# JWT
JWT_SECRET_KEY=changeme-super-secret-key

# Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
